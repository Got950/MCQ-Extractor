# --- Core ------------------------------------------------------------------
# Long random string; rotate to invalidate all JWTs.
APP_SECRET=change-me-in-prod
# Comma-separated Netlify / local origins (no trailing slash).
ALLOWED_ORIGIN=http://localhost:5173,https://your-app.netlify.app
ENVIRONMENT=dev

# --- MongoDB Atlas ---------------------------------------------------------
# Atlas → Connect → Drivers → copy connection string, then set user/password.
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=mcq_extractor

# Superadmin (created once by: python -m scripts.init_database)
SUPERADMIN_EMAIL=admin@example.com
SUPERADMIN_PASSWORD=change-me-strong-password
SUPERADMIN_MAX_UPLOADS=100

# --- LLM providers ---------------------------------------------------------
GEMINI_API_KEY=
# GEMINI_API_KEYS=key1,key2,key3
# GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_CHUNK_PAGES=3
# GEMINI_FALLBACK_MODEL=gemini-1.5-flash
OLLAMA_HOST=
OLLAMA_MODEL=qwen2.5vl

# --- Job queue -------------------------------------------------------------
REDIS_URL=
QUEUE_NAME=mcq-extractor

# --- Object storage --------------------------------------------------------
UPLOAD_DIR=
S3_BUCKET=
S3_REGION=
S3_ENDPOINT=

# --- Retention / cleanup ---------------------------------------------------
UPLOAD_TTL_HOURS=168

# --- Auth ------------------------------------------------------------------
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- Limits ----------------------------------------------------------------
MAX_UPLOAD_MB=50
MAX_UPLOADS_PER_USER=1
